+
+.collection-tile-img img {
+    width: 100%;
+    height: 100%;
+    object-fit: cover;
+    transition: transform 0.35s ease;
+}
+
+.collection-tile:hover .collection-tile-img img {
+    transform: scale(1.05);
+}
+
