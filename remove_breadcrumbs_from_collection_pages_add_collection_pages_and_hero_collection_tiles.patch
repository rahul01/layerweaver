diff --git a/shop/shop.css b/shop/shop.css
--- a/shop/shop.css	(revision af1376c536e751c6a859041f2d415f55b8c486c1)
+++ b/shop/shop.css	(revision 741bfe25c771983288958361e439d32ef7e4f809)
@@ -67,11 +67,139 @@
     background: rgba(160, 131, 213, 0.08);
 }
 
+/* ------- Collection Nav Strip ------- */
+.collection-nav {
+    display: flex;
+    gap: 8px;
+    flex-wrap: wrap;
+    margin-bottom: 32px;
+    padding-bottom: 24px;
+    border-bottom: 1px solid var(--gray);
+}
+
+.collection-nav-chip {
+    display: inline-block;
+    padding: 7px 18px;
+    border-radius: 50px;
+    border: 1.5px solid var(--gray);
+    background: var(--light);
+    font-family: var(--font-primary);
+    font-size: 0.8rem;
+    font-weight: 600;
+    text-transform: uppercase;
+    letter-spacing: 0.5px;
+    color: var(--gray-medium);
+    text-decoration: none;
+    transition: all 0.2s ease;
+    white-space: nowrap;
+}
+
+.collection-nav-chip:hover {
+    border-color: var(--primary);
+    color: var(--primary);
+    background: rgba(160, 131, 213, 0.06);
+}
+
+.collection-nav-chip.active {
+    background: var(--primary);
+    border-color: var(--primary);
+    color: var(--light);
+}
+
+@media (max-width: 600px) {
+    .collection-nav {
+        flex-wrap: nowrap;
+        overflow-x: auto;
+        padding-bottom: 12px;
+        scrollbar-width: none;
+        -webkit-overflow-scrolling: touch;
+        margin-bottom: 24px;
+    }
+    .collection-nav::-webkit-scrollbar { display: none; }
+    .collection-nav-chip { flex-shrink: 0; }
+}
+
+/* ------- Collection Topbar (breadcrumb + nav, above banner) ------- */
+.collection-topbar {
+    padding: 100px 0 0;
+}
+
+.collection-topbar .collection-nav {
+    margin-bottom: 0;
+    padding-bottom: 0;
+    border-bottom: none;
+}
+
+/* ------- Collection Banner ------- */
+.collection-banner {
+    position: relative;
+    width: 100%;
+    aspect-ratio: 16/5;
+    overflow: hidden;
+    background: var(--gray);
+    margin-top: 24px;
+}
+
+.collection-banner img {
+    width: 100%;
+    height: 100%;
+    object-fit: cover;
+}
+
+.collection-banner-overlay {
+    position: absolute;
+    inset: 0;
+    background: linear-gradient(to right, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.1) 60%, transparent 100%);
+    display: flex;
+    flex-direction: column;
+    justify-content: center;
+    padding: 0 60px;
+    gap: 10px;
+}
+
+.collection-banner-overlay h1 {
+    font-size: 2.4rem;
+    color: var(--light);
+    margin: 0;
+    text-shadow: 0 2px 8px rgba(0,0,0,0.3);
+}
+
+.collection-banner-overlay p {
+    font-size: 1rem;
+    color: rgba(255,255,255,0.85);
+    margin: 0;
+    max-width: 500px;
+}
+
+.collection-banner-text-only {
+    display: flex;
+    flex-direction: column;
+    align-items: center;
+    justify-content: center;
+    text-align: center;
+    background: linear-gradient(135deg, rgba(160,131,213,0.1) 0%, rgba(239,207,32,0.1) 100%);
+    padding: 40px 20px;
+}
+
+.collection-banner-text-only h1 { font-size: 2.2rem; margin: 0 0 8px; }
+.collection-banner-text-only p  { color: var(--gray-medium); margin: 0; }
+
+@media (max-width: 768px) {
+    .collection-banner { aspect-ratio: 16/7; margin-top: 64px; }
+    .collection-banner-overlay { padding: 0 28px; }
+    .collection-banner-overlay h1 { font-size: 1.6rem; }
+    .collection-banner-overlay p  { font-size: 0.9rem; }
+}
+
 /* ------- Product Grid (shop index) ------- */
 .shop-products {
     padding: 100px 0 80px;
 }
 
+.collection-page .shop-products {
+    padding: 32px 0 80px;
+}
+
 .shop-grid {
     display: grid;
     grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
